              "raw": "{{baseUrl}}/api/translate/property/{{propertyId}}?lang=en",
              "host": ["{{baseUrl}}"],
              "path": ["api", "translate", "property", "{{propertyId}}"],
              "query": [{ "key": "lang", "value": "en" }]
            }
          }
        },

        {
          "name": "Get Property Translated via Accept-Language Header",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "ar-MA,ar;q=0.9" }],
            "url": "{{baseUrl}}/api/translate/property/{{propertyId}}"
          }
        },

        {
          "name": "Get Agent Translated → English",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/translate/agent/{{agentId}}?lang=en",
              "host": ["{{baseUrl}}"],
              "path": ["api", "translate", "agent", "{{agentId}}"],
              "query": [{ "key": "lang", "value": "en" }]
            }
          }
        },

        {
          "name": "Force Re-translate Property Field [ADMIN]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/translate/property/{{propertyId}}/retranslate?fieldName=description&lang=ar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "translate", "property", "{{propertyId}}", "retranslate"],
              "query": [
                { "key": "fieldName", "value": "description" },
                { "key": "lang",      "value": "ar" }
              ]
            }
          }
        },

        {
          "name": "Evict Property Translations (cache clear) [ADMIN]",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/translate/property/{{propertyId}}"
          }
        },

        {
          "name": "Translation Stats [ADMIN]",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/translate/stats"
          }
        }

      ]
    },

    {
      "name": "📁 File Upload",
      "item": [
        {
          "name": "Upload Image [AGENT/ADMIN]",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/upload/image",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select an image file (JPG/PNG, max 5MB)"
                }
              ]
            }
          }
        },
        {
          "name": "Delete File [AGENT/ADMIN]",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/upload/photo_abc123.jpg"
          }
        }
      ]
    }

  ]
}
