{
  "info": {
    "name": "ImmoMaroc API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete API collection for ImmoMaroc backend — port 8090"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8090" },
    { "key": "token",   "value": "" },
    { "key": "agentId", "value": "1" },
    { "key": "propertyId", "value": "1" },
    { "key": "leadId",  "value": "1" },
    { "key": "sellRequestId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('✅ Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@immomaroc.ma\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },

    {
      "name": "👤 Agents",
      "item": [
        {
          "name": "Get All Agents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/agents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents"],
              "query": [
                { "key": "city", "value": "Casablanca", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get All Agents — Filter by City",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/agents?city=Casablanca",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents"],
              "query": [{ "key": "city", "value": "Casablanca" }]
            }
          }
        },
        {
          "name": "Get Agent by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/agents/{{agentId}}"
          }
        },
        {
          "name": "Create Agent [ADMIN]",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/agents",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Youssef Alami\",\n  \"email\": \"youssef@immomaroc.ma\",\n  \"password\": \"agent123\",\n  \"phone\": \"+212 6 12 34 56 78\",\n  \"whatsapp\": \"+212 6 12 34 56 78\",\n  \"agency\": \"ImmoMaroc Casablanca\",\n  \"city\": \"Casablanca\",\n  \"bio\": \"Expert immobilier avec 10 ans d'expérience à Casablanca.\",\n  \"verified\": true,\n  \"specialties\": [\"Appartements\", \"Villas\", \"Bureaux\"]\n}"
            }
          }
        },
        {
          "name": "Update Agent [ADMIN]",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/agents/{{agentId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Youssef Alami\",\n  \"email\": \"youssef@immomaroc.ma\",\n  \"phone\": \"+212 6 99 88 77 66\",\n  \"whatsapp\": \"+212 6 99 88 77 66\",\n  \"agency\": \"ImmoMaroc Premium\",\n  \"city\": \"Casablanca\",\n  \"bio\": \"Expert immobilier avec 12 ans d'expérience.\",\n  \"rating\": 4.8,\n  \"sold\": 45,\n  \"verified\": true,\n  \"specialties\": [\"Villas\", \"Riads\"]\n}"
            }
          }
        },
        {
          "name": "Toggle Agent Status [ADMIN]",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/agents/{{agentId}}/status"
          }
        },
        {
          "name": "Delete Agent [ADMIN]",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/agents/{{agentId}}"
          }
        },
        {
          "name": "Update My Profile [AGENT]",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/agents/me/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Youssef Alami\",\n  \"phone\": \"+212 6 12 34 56 78\",\n  \"whatsapp\": \"+212 6 12 34 56 78\",\n  \"agency\": \"ImmoMaroc Casablanca\",\n  \"city\": \"Casablanca\",\n  \"bio\": \"Votre conseiller de confiance.\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "🏠 Properties",
      "item": [
        {
          "name": "Search Properties — French (default)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/properties?page=0&size=12",
              "host": ["{{baseUrl}}"],
              "path": ["api", "properties"],
              "query": [
