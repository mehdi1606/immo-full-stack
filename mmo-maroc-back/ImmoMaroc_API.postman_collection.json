                { "key": "size", "value": "12" },
                { "key": "lang", "value": "fr", "disabled": true },
                { "key": "city", "value": "Casablanca", "disabled": true },
                { "key": "type", "value": "APPARTEMENT", "disabled": true },
                { "key": "purpose", "value": "VENTE", "disabled": true },
                { "key": "status", "value": "DISPONIBLE", "disabled": true },
                { "key": "minPrice", "value": "500000", "disabled": true },
                { "key": "maxPrice", "value": "3000000", "disabled": true },
                { "key": "minRooms", "value": "2", "disabled": true },
                { "key": "q", "value": "luxe", "disabled": true }
